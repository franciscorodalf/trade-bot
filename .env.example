# ============================================
# Polymarket BTC Prediction Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Polymarket (required for real trading, not needed for paper trading)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Trading Parameters
INITIAL_CAPITAL=100.0
KELLY_FRACTION=0.25
MIN_EDGE=0.03
MIN_BET=1.0
MAX_BET=25.0

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Web Dashboard
WEB_PORT=5500
