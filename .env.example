# ============================================
# AI Trading Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NOTE: .env is gitignored and will NOT be committed.
# The bot works without API keys (uses public data).

# Binance API (optional — only needed for live trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# Trading Parameters
INITIAL_CAPITAL=80.0
RISK_PER_TRADE=0.02
BUY_THRESHOLD=0.55
SELL_THRESHOLD=0.40
MAX_OPEN_POSITIONS=3
TIMEFRAME=1h
VOLATILITY_THRESHOLD=0.002
COMMISSION_RATE=0.0005
SLIPPAGE=0.0003

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Web Dashboard
WEB_PORT=5500
